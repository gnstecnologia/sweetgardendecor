# Copie para .env.local em desenvolvimento ou configure na Vercel (Settings → Environment Variables).

# Obrigatório em produção: mínimo 32 caracteres aleatórios.
SESSION_SECRET=

# Senha que a cliente usa em /admin/login
ADMIN_PASSWORD=

# Opcional em dev: sem isto usa ficheiro local-storage/site-data.json
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Opcional em dev: uploads gravam em public/uploads/
# BLOB_READ_WRITE_TOKEN=

# --- Vercel ---
# 1. Criar projeto a partir deste repositório (framework: Next.js).
# 2. Storage → criar KV e Blob; copiar variáveis para o projeto.
# 3. Definir SESSION_SECRET (32+ chars), ADMIN_PASSWORD, KV_*, BLOB_READ_WRITE_TOKEN.
# 4. Desativar GitHub Pages se existir, para evitar dois sites com dados diferentes.
